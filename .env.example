APP_NAME=AI Agent Memory Task
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./agent.db
GEMINI_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash-lite
LLM_TEMPERATURE=0.2
WORKER_POLL_INTERVAL_SECONDS=1.5
WORKER_MAX_CONCURRENCY=2
MEMORY_RELEVANCE_LIMIT=8
MEMORY_SUMMARY_CHAR_THRESHOLD=4000
RETRY_DELAY_SECONDS=5
